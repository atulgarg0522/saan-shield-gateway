# ------------------------------------------------------------------------------
# saan-ai-gateway Global Configuration Environment Variables Example
# ------------------------------------------------------------------------------

# Application Environment
APP_NAME=saan-ai-gateway
API_ENV=development # development, staging, production
DEBUG=true

# FastAPI Backend Settings
BACKEND_PORT=8000
SECRET_KEY=replace-with-a-secure-random-secret-key-for-jwt-and-cookies
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
LOG_LEVEL=info

# Database (PostgreSQL) Settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_password
POSTGRES_DB=saan_ai_gateway
POSTGRES_PORT=5432
POSTGRES_HOST=db
# asyncpg is used for the async connection in SQLAlchemy
DATABASE_URL=postgresql+asyncpg://postgres:postgres_secure_password@db:5432/saan_ai_gateway

# Redis Settings
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Next.js Frontend Settings (must be prefixed with NEXT_PUBLIC_ for client access)
NEXT_PUBLIC_API_URL=http://localhost:8000

# AI Provider Credentials (Outbound HTTP)
OPENAI_API_KEY=sk-proj-...
ANTHROPIC_API_KEY=sk-ant-...
COHERE_API_KEY=co-...
GEMINI_API_KEY=AIzaSy...

# Optional Monitoring and Observability
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
